// CrowdCarry - Prisma Schema (Highly Robust Cloud Version)
// Optimized for Vercel + Neon Deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // We use the pooled URL for the main connection
  url      = env("DATABASE_URL")
  // We add a directUrl for the build phase (This fixes the P1012 error on Vercel)
  directUrl = env("DIRECT_URL")
}

// Model definitions (Remain identical to ensure No code changes needed)
// ...
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  phone           String?   @unique
  emailVerified   DateTime?
  image           String?
  role            String    @default("BOTH")
  trustScore      Int       @default(90)
  aadhaarVerified Boolean   @default(false)
  bio             String?
  city            String?
  totalEarnings   Float     @default(0)
  totalDeliveries Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  trips        Trip[]
  packages     Package[]
  sentMessages Message[]    @relation("SentMessages")
  receivedMsgs Message[]    @relation("ReceivedMessages")
  ratingsGiven Rating[]     @relation("RatingGiver")
  ratingsRecvd Rating[]     @relation("RatingReceiver")
  transactions Transaction[]
  travelerDeliveries Delivery[] @relation("Traveler")
  senderDeliveries   Delivery[] @relation("Sender")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trip {
  id             String     @id @default(cuid())
  userId         String
  fromCity       String
  toCity         String
  departureDate  DateTime
  departureTime  String
  availableWeight Float
  pricePerKg     Float
  transportMode  String     @default("train")
  description    String?
  status         String     @default("UPCOMING")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries Delivery[]
}

model Package {
  id            String        @id @default(cuid())
  userId        String
  fromCity      String
  toCity        String
  weight        Float
  description   String
  urgency       String        @default("MEDIUM")
  preferredDate DateTime
  status        String        @default("POSTED")
  estimatedCost Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries Delivery[]
}

model Delivery {
  id           String         @id @default(cuid())
  tripId       String
  packageId    String
  travelerId   String
  senderId     String
  status       String         @default("PENDING")
  matchScore   Int            @default(0)
  pickupOtp    String?
  deliveryOtp  String?
  price        Float
  pickedUpAt   DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  trip     Trip    @relation(fields: [tripId], references: [id])
  package  Package @relation(fields: [packageId], references: [id])
  traveler User    @relation("Traveler", fields: [travelerId], references: [id])
  sender   User    @relation("Sender", references: [id], fields: [senderId])
  messages Message[]
  ratings  Rating[]
}

model Message {
  id         String   @id @default(cuid())
  deliveryId String
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  sender   User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Rating {
  id         String   @id @default(cuid())
  deliveryId String
  giverId    String
  receiverId String
  score      Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  giver    User     @relation("RatingGiver", fields: [giverId], references: [id])
  receiver User     @relation("RatingReceiver", fields: [receiverId], references: [id])
}

model Transaction {
  id            String            @id @default(cuid())
  userId        String
  type          String
  amount        Float
  status        String            @default("PENDING")
  razorpayId    String?
  upiId         String?
  description   String?
  createdAt     DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}
